    {
        "id": "f3b9f85bc1a87120",
        "type": "ui_template",
        "z": "06b1d32dae30de06",
        "group": "478dc27cf3cfa3fc",
        "name": "",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<style>\n    /* 1. FOND DE PAGE AVEC MOTIF RAYÉ (PATTERN) */\n    #dashboard-display {\n        background: #f0f0f0 !important;\n        background-image: repeating-linear-gradient(45deg, #e5e5e5 0, #e5e5e5 2px, transparent 0, transparent 50%) !important;\n        background-size: 15px 15px !important;\n        font-family: 'Arial Black', sans-serif !important;\n    }\n\n    /* 2. BARRE DE NAVIGATION ARC-EN-CIEL BRUTALE */\n    .md-toolbar-tools {\n        background-color: #000 !important;\n        border-bottom: 8px solid #FF00E4 !important; /* Rose Neon */\n    }\n\n    /* 3. CARTES (GROUPS) AVEC EFFET DE PERSPECTIVE */\n    .nr-dashboard-group {\n        background-color: #fff !important;\n        border: 5px solid #000 !important;\n        box-shadow: 12px 12px 0px #000 !important;\n        border-radius: 0px !important;\n        margin: 20px !important;\n        transition: all 0.2s ease;\n    }\n\n    .nr-dashboard-group:hover {\n        transform: translate(-4px, -4px);\n        box-shadow: 16px 16px 0px #FF00E4 !important; /* Change de couleur au survol */\n    }\n\n    /* 4. TITRES DES GROUPES (LOOK TICKET DE CAISSE / GLITCH) */\n    .nr-dashboard-group-title {\n        color: #fff !important;\n        font-weight: 900 !important;\n        letter-spacing: 2px;\n        text-transform: uppercase !important;\n        background: linear-gradient(90deg, #000 70%, #FF00E4 30%) !important;\n        padding: 12px !important;\n        border-bottom: 5px solid #000 !important;\n    }\n\n    /* 5. BOUTONS ULTRA-PEPS (CYAN / MAGENTA) */\n    .md-button.nr-dashboard-button {\n        background-color: #00F0FF !important; /* Cyan */\n        color: #000 !important;\n        border: 4px solid #000 !important;\n        box-shadow: 5px 5px 0px #000 !important;\n        border-radius: 0px !important;\n        text-transform: uppercase !important;\n        font-weight: 900 !important;\n        margin: 8px !important;\n    }\n\n    .md-button.nr-dashboard-button:hover {\n        background-color: #FF00E4 !important; /* Switch Magenta */\n        color: #fff !important;\n        transform: scale(1.05) rotate(-1deg);\n    }\n\n    /* 6. LABELS ET TEXTES (LOOK SURLIGNÉ) */\n    .nr-dashboard-label {\n        background-color: #FEFF00 !important; /* Jaune Fluos */\n        color: #000 !important;\n        display: inline-block !important;\n        padding: 2px 8px !important;\n        transform: rotate(-1deg);\n        border: 2px solid #000 !important;\n    }\n\n    /* 7. LES SWITCHES ET SLIDERS */\n    md-switch .md-bar {\n        background-color: #000 !important;\n    }\n    md-switch.md-checked .md-thumb {\n        background-color: #00FF41 !important;\n        border: 3px solid #000 !important;\n    }\n\n    /* ANIMATION DE FLASH POUR LE CÔTÉ VIVANT */\n    @keyframes blink {\n        0% { opacity: 1; }\n        50% { opacity: 0.8; }\n        100% { opacity: 1; }\n    }\n    \n    .nr-dashboard-group-title {\n        animation: blink 2s infinite;\n    }\n</style>",
