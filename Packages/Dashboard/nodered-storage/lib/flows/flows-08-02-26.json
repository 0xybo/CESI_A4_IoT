    {
        "id": "e33e0972f08998f4",
        "type": "ui_template",
        "z": "06b1d32dae30de06",
        "g": "d8396cf5f5930f6c",
        "group": "478dc27cf3cfa3fc",
        "name": "Security code UI/UX",
        "order": 1,
        "width": "7",
        "height": "6",
        "format": "<style>\n    :root {\n        --brutal-green: #00FF41;\n        --brutal-red: #FF5D5D;\n        --brutal-shadow: #000000;\n        --brutal-border: 4px solid #000000;\n        --brutal-disabled: #A0A0A0;\n    }\n\n    .brutal-container {\n        padding: 20px;\n        background-color: #ffffff;\n        font-family: 'Arial Black', sans-serif;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        gap: 20px;\n    }\n\n    .brutal-input {\n        font-size: 32px;\n        font-weight: 900;\n        letter-spacing: 5px;\n        text-align: center;\n        border: var(--brutal-border);\n        border-radius: 0px;\n        padding: 15px;\n        width: 180px;\n        background-color: var(--brutal-red);\n        color: black;\n        box-shadow: 8px 8px 0px var(--brutal-shadow);\n        outline: none;\n        transition: all 0.2s;\n    }\n\n    .brutal-input.valid {\n        background-color: var(--brutal-green);\n    }\n\n    .brutal-btn {\n        width: 100%;\n        max-width: 214px;\n        padding: 15px;\n        font-family: 'Arial Black', sans-serif;\n        font-size: 18px;\n        text-transform: uppercase;\n        border: var(--brutal-border);\n        background-color: var(--brutal-green);\n        box-shadow: 6px 6px 0px var(--brutal-shadow);\n        cursor: pointer;\n        transition: all 0.1s;\n    }\n\n    .brutal-btn:active:not([disabled]) {\n        transform: translate(3px, 3px);\n        box-shadow: 2px 2px 0px var(--brutal-shadow);\n    }\n\n    .brutal-btn[disabled] {\n        background-color: var(--brutal-disabled);\n        cursor: not-allowed;\n        box-shadow: none;\n        transform: none;\n        opacity: 0.6;\n    }\n\n    .brutal-status {\n        margin-top: 10px;\n        padding: 8px 15px;\n        background: black;\n        color: var(--brutal-green);\n        border: 2px solid black;\n        font-size: 14px;\n        text-transform: uppercase;\n    }\n\n    .shake {\n        animation: shake 0.2s cubic-bezier(.36,.07,.19,.97) both;\n    }\n\n    @keyframes shake {\n        10%, 90% { transform: translate3d(-1px, 0, 0); }\n        20%, 80% { transform: translate3d(2px, 0, 0); }\n        30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }\n        40%, 60% { transform: translate3d(4px, 0, 0); }\n    }\n</style>\n\n<div class=\"brutal-container\">\n    <div style=\"width: 100%; text-align: center;\">\n        <label style=\"display:block; margin-bottom:10px; font-weight:900;\">MQTT PIN CONTROL</label>\n        <input type=\"text\" \n               id=\"brutal-input-id\"\n               class=\"brutal-input\" \n               ng-class=\"{'valid': val.length === 4}\"\n               ng-model=\"val\" \n               ng-change=\"handleInput()\"\n               placeholder=\"0000\"\n               maxlength=\"4\"\n               inputmode=\"numeric\">\n    </div>\n\n    <button class=\"brutal-btn\" \n            ng-disabled=\"val.length !== 4\" \n            ng-click=\"submitData()\">\n        ENVOYER A L'ALARME\n    </button>\n\n    <div class=\"brutal-status\" ng-if=\"lastSent\">\n        CODE ACTIF: {{lastSent}}\n    </div>\n</div>\n\n<script>\n    (function(scope) {\n        scope.val = '';\n        scope.lastSent = '';\n        const inputElement = document.getElementById('brutal-input-id');\n\n        scope.handleInput = function() {\n            if (/[^0-9]/.test(scope.val)) {\n                inputElement.classList.add('shake');\n                setTimeout(() => inputElement.classList.remove('shake'), 200);\n            }\n            scope.val = scope.val.replace(/[^0-9]/g, '');\n        };\n\n        scope.submitData = function() {\n            if (scope.val.length === 4) {\n                scope.lastSent = scope.val;\n                scope.send({payload: scope.val});\n            }\n        };\n    })(scope);\n</script>\n",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": false,
        "templateScope": "local",
