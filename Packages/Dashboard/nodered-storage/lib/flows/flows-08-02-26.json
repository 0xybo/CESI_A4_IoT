    {
        "id": "bf80ab8709dffdb1",
        "type": "function",
        "z": "06b1d32dae30de06",
        "g": "91767edb076710d1",
        "name": "Set alarm state value and text",
        "func": "// Translate data to alarm state and alarm display string\n\nlet state = msg.payload?.data\n\nconst stateToDisplayString = {\n    0: \"Inactif\",\n    1: \"Surveillance\",\n    2: \"Déclenché\",\n    3: \"Désarmé\",\n    4: \"Désarmement raté\",\n    5: \"Configuration\",\n};\n\nif (state in stateToDisplayString) {\n    msg.payload.state = state;\n    msg.payload.stateString = stateToDisplayString[state];\n    return msg;\n} else { // Unknown state\n    msg.payload.state = -1;\n    msg.payload.stateString = \"Inconnu\";\n    return msg;\n}\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
