    {
        "id": "010ac86979a1b4bf",
        "type": "comment",
        "z": "06b1d32dae30de06",
        "name": "PayloadType",
        "info": "PayloadType {\n  EDGE_HEARTBEAT = 1, // Heartbeat message sent periodically to indicate that the system is alive, with the current alarm state included in the payload data\n  MOTION_STATE   = 2, // Message sent when motion is detected, with the motion state (e.g., detected or not detected) included in the payload data\n  CONFIGURATION  = 3, // TODO: Add support for configuration messages (e.g., changing the secret combination, time range rules, etc.)\n};",
        "x": 130,
        "y": 20,
        "wires": []
    },
