      "id": 1,
      "type": "stat",
      "title": "Luminosité ambiante (%)",
      "datasource": {
        "type": "influxdb",
        "name": "InfluxDB"
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"TestBucket\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"lighting\")\n  |> filter(fn: (r) => r._field == \"light_level\")\n  |> last()",
          "datasource": {
            "type": "influxdb",
            "name": "InfluxDB"
          }
        }
      ]
    },
