        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"TestBucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"lighting\")\n  |> filter(fn: (r) => r._field == \"light_level\")\n  |> aggregateWindow(every: 1m, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "datasource": {
            "type": "influxdb",
